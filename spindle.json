{
  "version": "0.1.2",
  "name": "Tracktor",
  "identifier": "tracktor",
  "author": "Trent",
  "github": "https://github.com/drinkwaterdrink/Tracktor-Lumiverse",
  "homepage": "https://github.com/drinkwaterdrink/Tracktor-Lumiverse",
  "description": "A customizable Lumiverse tracker extension inspired by zTracker, with schema presets, message metadata, generation, and prompt injection.",
  "permissions": ["generation", "chats", "chat_mutation", "interceptor", "ui_panels", "app_manipulation"],
  "entry_backend": "dist/backend.js",
  "entry_frontend": "dist/frontend.js",
  "minimum_lumiverse_version": "0.1.0",
  "interceptorTimeoutMs": 15000
}
